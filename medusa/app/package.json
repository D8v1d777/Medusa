{
  "name": "medusa",
  "version": "1.0.0",
  "description": "Medusa Security Research Framework",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.medusa.security",
    "productName": "Medusa",
    "directories": { "output": "release" },
    "files": ["dist/**", "index.html"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.developer-tools" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "ag-grid-community": "^30.0.0",
    "ag-grid-react": "^30.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "lucide-react": "^0.294.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
